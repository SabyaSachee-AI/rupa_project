# =============================================================================
# Rupa AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# Never commit .env to git.

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# One of: development, staging, production
RUPA_ENV=development

# Bind / serve settings (used by Docker)
APP_HOST=0.0.0.0
APP_PORT=8501

# -----------------------------------------------------------------------------
# LLM / AI provider keys
# -----------------------------------------------------------------------------
# OpenRouter is used for chat completions (default model: qwen/qwen-2.5-72b-instruct)
OPENROUTER_API_KEY=

# Groq is used for speech-to-text (Whisper Large v3)
GROQ_API_KEY=

# OpenAI is used for embeddings (text-embedding-3-small). Strongly recommended
# to use a real OpenAI key here; OpenRouter does not reliably proxy embeddings.
# If omitted, the app falls back to OpenRouter with a warning.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Vector database
# -----------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rupa-knowledge

# -----------------------------------------------------------------------------
# Database (persistent users, conversations, messages)
# -----------------------------------------------------------------------------
# SQLite (default, single-file, zero-config):
DATABASE_URL=sqlite:///data/rupa.db
# Postgres example:
# DATABASE_URL=postgresql+psycopg2://rupa:rupa@localhost:5432/rupa

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Random 32+ char secret used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_COOKIE_KEY=change-me-in-production-please
AUTH_COOKIE_NAME=rupa_auth
AUTH_COOKIE_EXPIRY_DAYS=30

# Initial admin user created on first boot if no users exist.
# REMOVE or rotate after first login.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW_SECONDS=300

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | console

# Optional Sentry error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
