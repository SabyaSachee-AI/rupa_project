# =============================================================================
# Streamlit Cloud secrets template
# =============================================================================
# In Streamlit Cloud go to: Manage app -> Settings -> Secrets, then paste
# the relevant values below (without the leading '#').
#
# Locally, copy this file to .streamlit/secrets.toml (gitignored) for testing.

# ---- Environment --------------------------------------------------------
RUPA_ENV = "production"

# ---- LLM providers ------------------------------------------------------
OPENROUTER_API_KEY = "sk-or-..."
GROQ_API_KEY       = "gsk-..."
OPENAI_API_KEY     = "sk-..."   # Strongly recommended for embeddings

CHAT_MODEL        = "qwen/qwen-2.5-72b-instruct"
EMBEDDING_MODEL   = "text-embedding-3-small"

# ---- Vector database ----------------------------------------------------
PINECONE_API_KEY   = "..."
PINECONE_INDEX_NAME = "rupa-knowledge"

# ---- Database -----------------------------------------------------------
# Streamlit Cloud is ephemeral; use a managed Postgres for persistence.
# DATABASE_URL = "postgresql+psycopg2://USER:PASS@HOST:5432/DBNAME"
DATABASE_URL = "sqlite:///data/rupa.db"

# ---- Auth ---------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_COOKIE_KEY    = "REPLACE_WITH_A_LONG_RANDOM_STRING"
AUTH_COOKIE_NAME   = "rupa_auth"
AUTH_COOKIE_EXPIRY_DAYS = 30

BOOTSTRAP_ADMIN_USERNAME = "admin"
BOOTSTRAP_ADMIN_EMAIL    = "you@example.com"
BOOTSTRAP_ADMIN_PASSWORD = "ChangeMeOnFirstLogin!"

# ---- Rate limiting ------------------------------------------------------
RATE_LIMIT_MESSAGES        = 30
RATE_LIMIT_WINDOW_SECONDS  = 300

# ---- Observability ------------------------------------------------------
LOG_LEVEL  = "INFO"
LOG_FORMAT = "json"

# SENTRY_DSN = "https://...@sentry.io/..."
# SENTRY_TRACES_SAMPLE_RATE = 0.1
